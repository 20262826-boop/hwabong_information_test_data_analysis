		<properties node_id="6" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x03\xbf\x00\x00\x04\x07\x00\x00\x00\x01\x00\x00\x00\x1f\x00\x00\x03\xbe\x00\x00\x04\x06\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x00\x01\x00\x00\x00\x1f\x00\x00\x03\xbe\x00\x00\x04\x06', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'import numpy as np\nfrom Orange.data import Table, Domain, ContinuousVariable, DiscreteVariable\n\ndomain = Domain([ContinuousVariable("age"),\n                 ContinuousVariable("height"),\n                 DiscreteVariable("gender", values=("M", "F"))])\narr = np.array([\n  [25, 186, 0],\n  [30, 164, 1]])\nout_data = Table.from_numpy(domain, arr)\n', 'filename': None}], 'scriptText': 'import numpy as np\nfrom Orange.data import Table, Domain, ContinuousVariable, DiscreteVariable\n\n# 1. 1부터 24까지의 시간 범주 생성\ntime_values = tuple(str(i) for i in range(1, 25))\n\ndomain = Domain([\n    DiscreteVariable("time", values=time_values),\n    ContinuousVariable("Electricity_Sum")  # 이름을 합계에 맞게 변경\n])\n\n# 2. 시간별 전력량 합계를 저장할 빈 딕셔너리 생성 (1~24시 초기화)\n# {1: 0.0, 2: 0.0, ..., 24: 0.0} 형태가 됩니다.\nelectricity_sums = {i: 0.0 for i in range(1, 25)}\n\n# 3. 데이터를 돌며 시간별로 전력량을 누적해서 더하기\nfor single_data in in_data:\n    time = int(single_data["거래시간"])\n    electricity = float(single_data["전력거래량(MWh)"])\n    \n    # 해당 시간에 전력량을 더해줍니다.\n    if time in electricity_sums:\n        electricity_sums[time] += electricity\n\n# 4. 합산된 결과를 Orange 데이터 배열(arr) 형태로 변환\narr = []\nfor time in range(1, 25):\n    # Orange의 DiscreteVariable 인덱스 규칙에 맞게 시간에서 1을 뺍니다 (0~23)\n    orange_time_idx = time - 1\n    total_electricity = electricity_sums[time]\n    \n    arr.append([orange_time_idx, total_electricity])\n\n# 5. Orange 테이블로 변환\narr = np.array(arr)\nout_data = Table.from_numpy(domain, arr)', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\x9f\x00\x00\x00`\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
